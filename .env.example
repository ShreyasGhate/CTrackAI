# ========================================
# CTrackAI Environment Configuration
# ========================================

# Emission factor (kg CO2/kWh)
EMISSION_FACTOR=0.727

# Region
REGION=maharashtra

# MQTT Broker (optional)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=ctrackai/readings/#

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_TIMEOUT_SECONDS=10

# Database
SQLITE_DB_PATH=./data/ctrackai_logs.db

# Logging
LOG_DIR=./logs
LOG_RETENTION_DAYS=90

# MLflow
MLFLOW_TRACKING_URI=./mlruns
